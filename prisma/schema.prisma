generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Account {
  id          String       @id @default(cuid())
  companyName String
  logoUrl     String?
  description   String?
  website       String?
  tagline       String?
  employeeCount String?
  foundedYear   Int?
  cultureValues String?
  benefits      String?
  orgNumber     String?
  vilectDepartmentId String? @unique
  createdAt   DateTime     @default(now())
  users       User[]
  listings    JobListing[]
  followers   CompanyFollow[]
}

model JobSeeker {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  createdAt    DateTime @default(now())

  cvText   String?
  cvParsed String?

  follows        CompanyFollow[]
  alerts         JobAlert[]
  applications   Application[]
  skillProfiles  CandidateSkillProfile[]
}

model User {
  id           String    @id @default(cuid())
  accountId    String
  account      Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  name         String
  email        String    @unique
  passwordHash String
  role         String    @default("USER")
  isOwner      Boolean   @default(false)
  lastActiveAt DateTime?
  createdAt    DateTime  @default(now())

  createdListings JobListing[] @relation("CreatedBy")
}

model JobListing {
  id          String  @id @default(cuid())
  accountId   String
  account     Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  createdById String
  createdBy   User    @relation("CreatedBy", fields: [createdById], references: [id])
  skillProfiles JobSkillProfile[]

  title        String?
  body         String?
  contactName  String?
  contactTitle String?
  contactEmail String?
  logoUrl      String?

  applicationDeadline DateTime?

  location    String?
  industry    String?
  jobCategory String?

  salaryMin  Int?
  salaryMax  Int?
  salaryType String?

  vilectId   String? @unique
  source     String?

  receiptMethod String?
  receiptEmail  String?
  receiptUrl    String?

  status           String    @default("DRAFT")
  firstPublishedAt DateTime?
  publishedAt      DateTime?
  expiresAt        DateTime?

  viewCount       Int @default(0)
  applyClickCount Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  applications Application[]
}

model JobAlert {
  id          String     @id @default(cuid())
  email       String
  jobSeekerId String?
  jobSeeker   JobSeeker? @relation(fields: [jobSeekerId], references: [id], onDelete: Cascade)
  name        String?
  bransje     String?
  kategori    String?
  sted        String?
  token       String     @unique @default(cuid())
  createdAt   DateTime   @default(now())
  lastSentAt  DateTime?
}

model CompanyFollow {
  id             String     @id @default(cuid())
  email          String
  followerName   String?
  jobSeekerId    String?
  jobSeeker      JobSeeker? @relation(fields: [jobSeekerId], references: [id], onDelete: Cascade)
  accountId      String
  account        Account    @relation(fields: [accountId], references: [id], onDelete: Cascade)
  token          String     @unique @default(cuid())
  createdAt      DateTime   @default(now())

  @@unique([email, accountId])
}

model Application {
  id           String     @id @default(cuid())
  jobListingId String
  jobListing   JobListing @relation(fields: [jobListingId], references: [id], onDelete: Cascade)
  jobSeekerId  String?
  jobSeeker    JobSeeker? @relation(fields: [jobSeekerId], references: [id], onDelete: SetNull)

  applicantName  String
  applicantEmail String
  applicantPhone String?
  coverText      String?
  cvFileUrl      String?

  status      String   @default("INNSENDT")
  statusNote  String?
  updatedAt   DateTime @updatedAt

  submittedAt DateTime @default(now())
}

// ESCO-referansedata (populeres on-demand ved synk og CV-parsing)
model EscoSkill {
  uri              String  @id
  preferredLabelNb String?
  preferredLabelEn String?
  skillType        String?

  jobProfiles       JobSkillProfile[]
  candidateProfiles CandidateSkillProfile[]
}

// Kompetanseprofil per stilling (signal: 'extracted' fra tekst)
model JobSkillProfile {
  id           String     @id @default(cuid())
  jobListingId String
  jobListing   JobListing @relation(fields: [jobListingId], references: [id], onDelete: Cascade)
  skillUri     String
  skill        EscoSkill  @relation(fields: [skillUri], references: [uri])
  weight       Float      @default(1.0)
  signal       String     @default("extracted")
  createdAt    DateTime   @default(now())

  @@unique([jobListingId, skillUri])
}

// Kompetanseprofil per kandidat (fra CV-analyse)
model CandidateSkillProfile {
  id          String    @id @default(cuid())
  jobSeekerId String
  jobSeeker   JobSeeker @relation(fields: [jobSeekerId], references: [id], onDelete: Cascade)
  skillUri    String
  skill       EscoSkill @relation(fields: [skillUri], references: [uri])
  confidence  Float     @default(1.0)
  createdAt   DateTime  @default(now())

  @@unique([jobSeekerId, skillUri])
}
